{
  "name": "daptin-cli",
  "version": "0.1.0",
  "description": "Command-line interface for Daptin Backend-as-a-Service",
  "main": "dist/index.js",
  "bin": {
    "daptin-cli": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --clean --shims",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "daptin",
    "cli",
    "baas",
    "backend-as-a-service",
    "json-api",
    "rest-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
